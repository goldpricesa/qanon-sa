# --- Telegram ---
TELEGRAM_BOT_TOKEN=replace-with-bot-token-from-botfather

# --- Database ---
# Production: postgresql+asyncpg://user:pass@db:5432/qanonbot
# Dev: sqlite+aiosqlite:///./data/qanonbot.db
DATABASE_URL=postgresql+asyncpg://qanonbot:qanonbot@db:5432/qanonbot
POSTGRES_USER=qanonbot
POSTGRES_PASSWORD=qanonbot
POSTGRES_DB=qanonbot

# --- Ollama (local LLM) ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_ANSWER_MODEL=qwen2.5:7b-instruct
OLLAMA_CLASSIFIER_MODEL=qwen2.5:7b-instruct
LLM_FUSED_MODE=false

# --- Admin panel ---
ADMIN_SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=ChangeMe!2026
ADMIN_BASE_PATH=/admin
ADMIN_SESSION_HOURS=12
ADMIN_COOKIE_SECURE=false

# --- Moderation defaults (also stored in DB settings; env are bootstrap only) ---
DEFAULT_MUTE_HOURS=12
WARN_THRESHOLD=1
MUTE_THRESHOLD=2
RATE_LIMIT_PER_HOUR=20
RAG_TOP_K=4
CLASSIFIER_CONFIDENCE_MIN=0.6

# --- Site contact (mirrored from src/lib/site.ts) ---
SITE_NAME=نظرة قانونية
SITE_URL=https://www.qanon-sa.com
SITE_CONTACT_PHONE=0560390004
SITE_CONTACT_TEL=+966560390004
SITE_WHATSAPP=https://wa.me/966560390004

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs

# --- Embeddings ---
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DIM=768

# --- Bot mode ---
BOT_MODE=polling
# When BOT_MODE=webhook, set:
# WEBHOOK_BASE_URL=https://your.domain
# WEBHOOK_PATH=/tg/webhook
# WEBHOOK_SECRET=long-random-string
